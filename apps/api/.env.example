# ── Application ────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ── JWT ────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_32_char_string
JWT_EXPIRES_IN=24h

# ── Supabase ───────────────────────────────────────────────────
# Service-role key bypasses RLS — keep this secret and NEVER expose it to the frontend
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# ── Redis ──────────────────────────────────────────────────────
# Password must match the one in docker-compose.yml
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=localredis

# ── Zoom ───────────────────────────────────────────────────────
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET=

# ── Mux ────────────────────────────────────────────────────────
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_SIGNING_KEY_ID=
MUX_SIGNING_PRIVATE_KEY=
MUX_WEBHOOK_SECRET=

# ── Email (nodemailer via Gmail SMTP) ─────────────────────────
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_16_char_app_password
