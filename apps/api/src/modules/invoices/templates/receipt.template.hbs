<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <style>
    * {{ box-sizing: border-box; margin: 0; padding: 0; }}
    body {{ font-family: 'Segoe UI', Arial, sans-serif; font-size: 12px; color: #333; padding: 30px; }}
    .header {{ display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #1a73e8; padding-bottom: 15px; margin-bottom: 20px; }}
    .header .logo {{ max-height: 60px; }}
    .header h1 {{ color: #1a73e8; font-size: 22px; margin: 0; }}
    .header .subtitle {{ color: #666; font-size: 11px; }}
    .address {{ margin-bottom: 20px; }}
    .address p {{ line-height: 1.6; }}
    .meta {{ display: flex; justify-content: space-between; margin-bottom: 20px; padding: 10px 0; border-bottom: 1px solid #ddd; }}
    .meta strong {{ display: block; font-size: 11px; color: #666; }}
    .meta span {{ font-size: 13px; }}
    table {{ width: 100%; border-collapse: collapse; margin-bottom: 20px; }}
    th, td {{ padding: 8px 10px; text-align: left; border-bottom: 1px solid #eee; }}
    th {{ background: #f5f5f5; font-size: 11px; text-transform: uppercase; color: #666; }}
    td {{ font-size: 12px; }}
    td.amount {{ text-align: right; }}
    .totals {{ width: 300px; margin-left: auto; }}
    .totals td {{ padding: 5px 10px; }}
    .totals .label {{ text-align: left; font-size: 11px; color: #666; }}
    .totals .value {{ text-align: right; font-size: 12px; }}
    .totals .grand-total td {{ font-weight: bold; font-size: 14px; border-top: 2px solid #1a73e8; padding-top: 8px; }}
    .footer {{ margin-top: 30px; padding-top: 15px; border-top: 1px solid #ddd; text-align: center; font-size: 10px; color: #999; }}
    .badge {{ background: #e8f0fe; color: #1a73e8; padding: 3px 8px; border-radius: 4px; font-size: 10px; font-weight: bold; }}
  </style>
</head>
<body>
  <div class="header">
    <div>
      <h1>Payment Receipt</h1>
      <p class="subtitle">GST Invoice / Receipt for Educational Services</p>
    </div>
    <div>
      {{#if businessLogo}}<img class="logo" src="{{businessLogo}}" alt="Logo" />{{/if}}
      <p><strong>{{receiptNumber}}</strong></p>
    </div>
  </div>

  <div class="address">
    <p>
      <strong>{{businessName}}</strong><br />
      {{businessAddress}}<br />
      {{#if businessGst}}GSTIN: {{businessGst}}{{/if}}
    </p>
  </div>

  <div class="meta">
    <div><strong>Receipt No.</strong><span>{{receiptNumber}}</span></div>
    <div><strong>Date</strong><span>{{date}}</span></div>
    <div><strong>Student</strong><span>{{studentName}}</span></div>
    <div><strong>Email</strong><span>{{studentEmail}}</span></div>
  </div>

  <div class="meta">
    <div><strong>Course</strong><span>{{courseName}}</span></div>
    <div><strong>Payment Method</strong><span>{{paymentMethod}}</span></div>
    {{#if transactionId}}<div><strong>Transaction ID</strong><span class="badge">{{transactionId}}</span></div>{{/if}}
    {{#if installmentNumber}}<div><strong>Installment</strong><span>{{installmentNumber}}</span></div>{{/if}}
  </div>

  <table>
    <thead>
      <tr><th>Description</th><th class="amount">Amount (&#x20B9;)</th></tr>
    </thead>
    <tbody>
      <tr><td>Tuition Fee {{#if installmentNumber}}(Installment {{installmentNumber}}){{/if}}</td><td class="amount">{{baseAmount}}</td></tr>
      <tr><td>CGST @ 9%</td><td class="amount">{{cgstAmount}}</td></tr>
      <tr><td>SGST @ 9%</td><td class="amount">{{sgstAmount}}</td></tr>
    </tbody>
  </table>

  <table class="totals">
    <tr><td class="label">Subtotal</td><td class="value">{{baseAmount}}</td></tr>
    <tr><td class="label">CGST (9%)</td><td class="value">{{cgstAmount}}</td></tr>
    <tr><td class="label">SGST (9%)</td><td class="value">{{sgstAmount}}</td></tr>
    <tr class="grand-total"><td class="label">Total Paid</td><td class="value">&#x20B9; {{totalAmount}}</td></tr>
  </table>

  <div class="footer">
    <p>This is a computer-generated receipt and does not require a physical signature.</p>
    <p>{{businessName}} | {{businessAddress}}</p>
  </div>
</body>
</html>
